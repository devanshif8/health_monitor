# Keep the build context tiny — never ship these into the image.
venv/
seris/
.venv/
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Generated at container start (into the data volume), not baked in.
data/patients/
data/patients_manifest.csv
data/forecast_eval_summary.csv
*.db
*.sqlite*

# Logs / artifacts / docs
*.log
*.pptx

# Frontend (its own image builds from frontend/ context)
frontend/node_modules/
frontend/dist/

# Local config & VCS
.env
.git/
.github/
.gitignore
tests/
